{
  "name": "vozvenda",
  "version": "1.0.0",
  "description": "VozVenda — Reconhecimento de Vendas por Voz",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:unsigned": "electron-builder --win --x64 --config.forceCodeSigning=false"
  },
  "build": {
    "appId": "com.vozvenda.app",
    "productName": "VozVenda",
    "publish": [
      {
        "provider": "github",
        "owner": "vozvenda",
        "repo": "vozvenda-releases",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": ["sha256"],
      "certificateFile": "${env.WIN_CERT_PATH}",
      "certificatePassword": "${env.WIN_CERT_PASSWORD}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false
    },
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.1.7",
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
